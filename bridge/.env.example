# pulse-bridge Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# Misskey Webhook Settings (Required)
# ===========================================

# Secret for validating incoming webhooks from Misskey
PULSE_MISSKEY_HOOK_SECRET=your-webhook-secret-here

# Header name for webhook secret (default: X-Misskey-Hook-Secret)
# PULSE_MISSKEY_HOOK_SECRET_HEADER=X-Misskey-Hook-Secret

# ===========================================
# Misskey API Settings (for reply notifier)
# ===========================================

# Misskey API base URL (e.g., https://misskey.example.com/api)
PULSE_MISSKEY_API_URL=https://your-misskey-instance.com/api

# Misskey API token for posting replies
# Generate from: Settings > API > Generate Access Token
PULSE_MISSKEY_API_TOKEN=your-api-token-here

# ===========================================
# Taskstate Settings (Required)
# ===========================================

# Path to SQLite database for agent-taskstate
PULSE_TASKSTATE_DB=/path/to/agent-taskstate.db

# Optional: Custom path to agent-taskstate CLI
# Default: {repo_root}/agent-taskstate/docs/src/agent-taskstate_cli.py
# PULSE_TASKSTATE_CLI_PATH=/path/to/agent-taskstate_cli.py

# ===========================================
# Kestra Settings (Required)
# ===========================================

# Kestra base URL
PULSE_KESTRA_BASE_URL=http://localhost:8080

# Kestra namespace for pulse flows
PULSE_KESTRA_NAMESPACE=pulse

# Kestra flow ID for mention processing
PULSE_KESTRA_FLOW_ID=mention

# Webhook key for triggering Kestra flows
PULSE_KESTRA_WEBHOOK_KEY=your-webhook-key-here

# ===========================================
# Kestra Basic Auth (Optional)
# ===========================================

# Uncomment if Kestra requires Basic Auth
# PULSE_KESTRA_BASIC_USER=
# PULSE_KESTRA_BASIC_PASS=